{
  "languages": {
    "Lua": {
      "format_on_save": "off",
    },
  },
  "lsp": {
    "clangd": {
      "binary": {
        "path": "clangd",
        "arguments": [
          "--compile-commands-dir=cpp",
          "--background-index",
          "--clang-tidy",
        ],
      },
    },
    "lua-language-server": {
      "settings": {
        "Lua": {
          "diagnostics": {
            "enable": false,
          },
          "format": {
            "enable": false,
          },
        },
      },
    },
  },
}
