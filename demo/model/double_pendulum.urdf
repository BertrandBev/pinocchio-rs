<?xml version="1.0" ?>
<robot name="double_pendulum">
  <link name="world" />

  <link name="link1">
    <visual>
      <origin xyz="0 0 -0.5" />
      <geometry>
        <cylinder radius="0.02" length="1.0" />
      </geometry>
    </visual>
    <inertial>
      <origin xyz="0 0 -0.5" />
      <mass value="1.0" />
      <inertia
                ixx="0.08"
                ixy="0.0"
                ixz="0.0"
                iyy="0.08"
                iyz="0.0"
                izz="0.001"
            />
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="world" />
    <child link="link1" />
    <axis xyz="0 1 0" />
    <limit lower="-3.14159" upper="3.14159" effort="100.0" velocity="100.0" />
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 -0.5" />
      <geometry>
        <cylinder radius="0.02" length="1.0" />
      </geometry>
    </visual>
    <inertial>
      <origin xyz="0 0 -0.5" />
      <mass value="1.0" />
      <inertia
                ixx="0.08"
                ixy="0.0"
                ixz="0.0"
                iyy="0.08"
                iyz="0.0"
                izz="0.001"
            />
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1" />
    <child link="link2" />
    <origin xyz="0 0 -1.0" />
    <axis xyz="0 1 0" />
    <limit lower="-3.14159" upper="3.14159" effort="100.0" velocity="100.0" />
  </joint>
</robot>
